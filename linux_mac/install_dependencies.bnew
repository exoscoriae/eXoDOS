function goNixenv
{
    printf "\n\e[1;37;41mWARNING: NixOS IS NOT FHS COMPLIANT\e[0m\n\e[1;31;47mWe make no promises that any eXo collections will work with it.\e[0m\n\n"
    command -v nix-env &>/dev/null || { echo "Missing nix-env!"; failedInstall; }
    local missing_pkgs=()
    
    { command -v fold && command -v sha256sum; } &>/dev/null || missing_pkgs+=("nixos.coreutils")
    command -v unzip &>/dev/null || missing_pkgs+=("nixos.unzip")
    command -v wget &>/dev/null || missing_pkgs+=("nixos.wget")
    
    if [ "$run_update" != "yes" ]
    then
        command -v tput &>/dev/null || missing_pkgs+=("nixos.ncurses")
        for check in curl ffmpeg flatpak perl python3 zip
        do
            command -v "$check" &>/dev/null || missing_pkgs+=("nixos.$check")
        done
        command -v sed &>/dev/null || missing_pkgs+=("nixos.gnused")
    fi

    if [ ${#missing_pkgs[@]} -gt 0 ]
    then
        printf "\nBeginning dependency installation...\n\n"
        echo "Attempting to install missing packages via nix-env: ${missing_pkgs[*]}"
        nix-env -iA "${missing_pkgs[@]}" || failedInstall
    fi
    [ "$run_update" == "yes" ] && getUpdate
    extractPackages
    installFlatpaks
}

