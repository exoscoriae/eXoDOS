function installFlatpaks
{
    if [ "$(uname -m)" == "x86_64" ]
    then
        flatpak_ext="x86_64.flatpak"
    elif [ "$(uname -m)" == "aarch64" ]
    then
        flatpak_ext="aarch64.flatpak"
    else
        echo "Unsupported architecture: $(uname -m)"
        exit 1
    fi
    flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo || failedInstall
    if [ "$(uname -m)" == "x86_64" ]
    then
        flatpak install --user --reinstall -y flathub org.freedesktop.Platform.Compat.i386//25.08
        flatpak install --user --reinstall -y flathub org.freedesktop.Platform.codecs_extra.i386//25.08-extra
        flatpak install --user --reinstall -y flathub org.freedesktop.Platform.GL32.default//25.08
        for dev in /sys/bus/pci/devices/*
        do
            [ -f "$dev/class" ] || continue
            read -r class < "$dev/class"
            if [[ "$class" == 0x03* ]]
            then
                read -r vendor < "$dev/vendor"
                [[ "$vendor" == "0x8086" ]] && flatpak install --user --reinstall -y flathub org.freedesktop.Platform.VAAPI.Intel.i386//25.08
                [[ "$vendor" == "0x10de" ]] && flatpak install --user --reinstall -y flathub org.freedesktop.Platform.VAAPI.nvidia.i386//25.08
            fi
        done
    fi
    flatpak update --user -y || failedInstall

    echo "Installing retro_exo flatpaks..."
    shopt -s nullglob
    for pkg in ./eXo/Flatpaks/*.$flatpak_ext
    do
        if flatpak ps --columns=application | grep -q "^$(basename "${pkg%.$flatpak_ext}")$"
        then
            if [ "$(basename "${pkg%.$flatpak_ext}")" == "com.retro_exo.konsole" ]
            then
                echo "An instance of com.retro_exo.konsole is currently running. Skipping..."
                continue
            else
                echo "Killing running instance of $(basename "${pkg%.$flatpak_ext}")..."
                flatpak kill "$(basename "${pkg%.$flatpak_ext}")"
            fi
        fi
        flatpak info "`basename "${pkg%.$flatpak_ext}"`" &>/dev/null && flatpak remove --delete-data -y "`basename "${pkg%.$flatpak_ext}"`"
        flatpak install --user --reinstall -y "$pkg" || failedInstall
        #https://github.com/flatpak/flatpak/pull/5546
        #Note that --reinstall will not work until the above flatpak pull request is rolled out, work around implemented in prior line
    done
    shopt -u nullglob
}

function setupOther
{
    if [ "$run_update" == "yes" ]
    then
        { command -v fold && command -v sha256sum; } &>/dev/null || abortScript "Coreutils (sha256sum/fold) is not present. Please install it before proceeding."
        command -v unzip &>/dev/null || abortScript "Unzip is not present. Please install it before proceeding."
        command -v wget &>/dev/null || abortScript "Wget is not present. Please install it before proceeding."
        getUpdate
    fi
    
    if [ "$missing_packages" == "no" ]
    then
        printf "\nSystem dependencies satisfied. Proceeding to install flatpaks.\n\n"
        extractPackages
        installFlatpaks
    elif [ "$missing_packages" == "yes" ]
    then
        printf "\nYour distribution, $distro_id, is not officially supported.\n%s\n\n%s\n%s\n\n%s\n\n" \
            "As such, you will need to install the missing system dependencies manually." \
            "If a problem is encountered, you may make a support request in our Discord." \
            "If support is added, you will need to update this installer to access it." \
            "After you have installed the required packages, rerun this setup."
        read -s -n 1 -p "Press any key to abort."
        printf "\n\n"
        exit 1
    fi
}

if [[ "$LD_PRELOAD" =~ "gameoverlayrenderer" ]]
then
    LD_PRELOAD=""
fi
clear

setupversion="Version 6.04b.universal1_beta6"

[[ $0 == $BASH_SOURCE ]] && cd "$( dirname "$0")"
scriptDir="$(cd "$( dirname "$BASH_SOURCE")" && pwd)"
[ $# -gt 0 ] && parameterone="$1"
[ $# -gt 1 ] && parametertwo="$2"
[ $# -gt 2 ] && parameterthree="$3"
[ $# -gt 3 ] && parameterfour="$4"

if [[ "${BASH_SOURCE[0]}" == *.bsh ]]
then
    cd ../..
    updated_uds="$PWD/eXo/Update/linux_mac/$(basename -- "${BASH_SOURCE%.bsh}.bnew")"
    if [[ -f "$updated_uds" ]]
    then
        new_version=$(grep -m 1 '^setupversion=' "$updated_uds" | cut -d'"' -f2)
        if [[ -n "$new_version" && "$setupversion" != "$new_version" ]]
        then
            source "$updated_uds"
            exit 0
        fi
    fi
    macUDSext=command
    linUDSext=bsh
    udspath="."
elif [[ "${BASH_SOURCE[0]}" == *.bnew ]]
then
    cd "$scriptDir/../../.."
    scriptDir="$PWD"
    macUDSext=cnew
    linUDSext=bnew
    udspath="eXo/Update/linux_mac"
else
    abortScript "Invalid script extension!"
fi

if [[ "$OSTYPE" == "darwin"* ]]
then
    source "$scriptDir/$udspath/$(basename -- "${BASH_SOURCE%.$linUDSext}.$macUDSext")"
    exit 0
fi

[ ! -d Content ] && abortScript "Cannot find ./Content subdirectory."
[ ! -d "eXo/util" ] && abortScript "Cannot find ./eXo/util subdirectory."
[[ $(ls -1 eXo/util/util*linux*.zip 2>/dev/null | wc -l) == 0 ]] && abortScript "Cannot find ./eXo/util/util*linux*.zip."
chmod +x *.command

initialDir=$PWD

beginLinux
