#!/usr/bin/env bash

# Linux Dependency Setup For eXo Collections
# Revised: 2026-05-31

#--------------------------------------------------------------------------------------
shopt -s extglob
function abortScript
{
    printf "\n\e[1;31;47m%s\e[0m\n\n" "$1"
    read -s -n 1 -p "Press any key to abort."
    printf "\n\n"
    exit 1
}

function beginLinux
{
    missing_packages=no
    remove_exo=no
    run_update=no
    distro_id="$(cat /etc/os-release 2>/dev/null | grep '^ID=' | sed -e 's/^ID=//' | sed -e 's/"//g')"
    distro_like="$(cat /etc/os-release 2>/dev/null | grep '^ID_LIKE=' | sed -e 's/^ID_LIKE=//')"
    
    clear
    if [ "$parameterone" == "update" ]
    then
        run_update=yes
    else
        printf "\n\e[1;31;40mWelcome to the eXo Dependency Installer.\e[0m\n\n%s\n%s\n%s\n%s\n\n" \
            "This setup will install the software required by the collection." \
            "If system packages are needed, you may be asked for your password (for sudo)." \
            "If your account lacks sudo access, this script cannot install system packages." \
            "In such cases, you will need to install the missing system packages yourself."
        printf "Please choose one of the following:\n\n%s\e[1;37;45m%s\e[0m%s\n%s\e[1;37;45m%s\e[0m%s\n%s\e[1;37;45m%s\e[0m%s\n%s\e[1;37;45m%s\e[0m%s\n\n" \
            "[" "P" "]roceed with installation" "[" "D" "]ownload updates" "[" "R" "]emove all installed eXo packages" "[" "A" "]bort installation"
        while true
        do
            read -p "(P/D/R/A)? " choice
            case $choice in
                [Pp]* ) break;;
                [Dd]* ) run_update=yes
                        break;;
                [Rr]* ) remove_exo=yes
                        break;;
                [Aa]* ) printf "\n"
                        exit 0
                        break;;
                *     ) printf "Invalid input.\n";;
            esac
        done
    fi
    if [ "$remove_exo" == "yes" ]
    then
        clear
        printf "This will uninstall all eXo flatpaks from your system.\n%s" \
            "Are you sure you want to proceed? "
        while true
        do
            read -p "(Y/N)? " choice
            case $choice in
                [Yy]* ) break;;
                [Nn]* ) exit 0
                        break;;
                *     ) printf "Invalid input.\n";;
            esac
        done
        command -v flatpak &>/dev/null || abortScript "flatpak is not present. There are no eXo packages to uninstall."
        flatpak list | grep -q "com.retro_exo" || abortScript "There are no eXo packages to uninstall."
        for package in `flatpak list | grep com.retro_exo | sed -e 's/^.*com.retro_exo/com.retro_exo/' | sed -e 's/[[:space:]].*//'`
        do
            flatpak remove --delete-data -y "$package" 2>/dev/null || abortScript "Failed to uninstall $package package."
        done
        printf "\nAll eXo flatpaks have been successfully uninstalled.\n"
        read -s -n 1 -p "Press any key to exit."
        exit 0
    fi
    
    clear
    printf "Checking for missing system packages...\n\n"
    for check in curl ffmpeg flatpak fold perl python3 sed sha256sum tput unzip wget zip
    do
        command -v "$check" &>/dev/null && printf "%s: \e[1;37;44mpresent\e[0m\n" "$check" || { missing_packages=yes; printf "%s: \e[1;37;41mmissing\e[0m\n" "$check"; }
    done
    if [ "$missing_packages" == "yes" ]
    then
        printf "\nNot all system dependencies installed.\n"
        read -s -n 1 -p "Press any key to proceed..."
        case "$distro_id" in
            alpine ) goApk;;
            debian|elementary|linuxmint|pop|ubuntu|zorin ) goApt;;
            almalinux|centos|fedora|rhel|rocky ) goDnf;;
            solus ) goEopkg;;
            nixos ) goNixenv;;
            arch|endeavouros|garuda|manjaro ) goPacman;;
            void ) goXbps;;
            opensuse*|sles|suse ) goZypper;;
            * ) case "$distro_like" in
                    *alpine* ) goApk;;
                    *debian*|*ubuntu* ) goApt;;
                    *centos*|*fedora*|*rhel* ) goDnf;;
                    *solus* ) goEopkg;;
                    *arch* ) goPacman;;
                    *void* ) goXbps;;
                    *suse* ) goZypper;;
                    * ) setupOther;;
                esac;;
        esac
    else
        printf "\nAll system dependencies satisfied.\n"
        read -s -n 1 -p "Press any key to proceed..."
        [ "$run_update" == "yes" ] && getUpdate
        extractPackages
        installFlatpaks
    fi
    
    clear
    if [ "$parameterone" == "update" ]
    then
        printf "\nUpdates complete.\n%s\e[1;37;44m%s\e[0m%s\n\n" \
            "You may launch exogui with the desktop icon or the " "exogui.command" " script."
    else
        printf "\nAll required dependencies are now satisfied.\n%s\e[1;33;40m%s\e[0m%s\n\n" \
            "You may proceed with running the appropriate " "Setup eXo<collection>.command" " file."
    fi
    read -s -n 1 -p "Press any key to exit..."
    printf "\n\n"
}

# File naming convention for Linux/macOS Content containing packages:
# A Linux/macOS patch must follow one of two naming conventions depending on whether its files need to be extracted last.
#
# If a collection does not require Linux/MacOS Content to be extracted last:
# Base pack : XO*_linux*_Metadata.zip (e.g. XODOS_linuxmac_Metadata.zip)
# Base language pack: eXo*_linux*_Metadata.zip (e.g. eXoDOS_SLP_linuxmac_Metadata.zip)
# Addon, standard pack: ${pack_id}_linux*_*.zip (e.g. DOS_linuxmac_Videos.zip)
# Addon, language pack: eXo${pack_id}_Addonpack_linux*_*.zip (e.g. eXoDOS_GLP_Addonpack_linuxmac_MagazinesGLP.zip)
#
# If a collection requires Linux/MacOS Content to be extracted last:
# Base pack: XO*zz_linux*_Metadata.zip (e.g. XODOSzz_linuxmac_Metadata.zip)
# Base language pack: eXo*zz_linux*_Metadata.zip (e.g. eXoDOS_SLPzz_linuxmac_Metadata.zip)
# Addon, standard pack: ${pack_id}zz_linux*_*.zip (e.g. DOSzz_linuxmac_Videos.zip)
# Addon, language pack: eXo${pack_id}_Addonpackzz_linux*_*.zip (e.g. eXoDOS_GLP_Addonpackzz_linuxmac_MagazinesGLP.zip)
#
# Note that base Linux packs must contain eXo/Update/linux_mac/getVer_${pack_id}.sh files for updates to work!
# Update package naming conventions listed by getUpdate function.
function extractPackages
{
    printf "\nExtracting packages...\n"
    cd eXo
    rm -rf ./dmg/*/ &>/dev/null
    rm -rf ./emulators/*/macOS/*.app ./emulators/*/*/macOS/*.app ./emulators/*/*/*/macOS/*.app &>/dev/null
    for zip_file in ./util/util*_linux*.zip
    do
        [ -e "$zip_file" ] || continue
        unzip -o "$zip_file" 'EXT*_linux*.zip' -d ./util || abortScript "Failed to unzip EXT packages."
    done
    for zip_file in ./util/EXT*_linux*.zip
    do
        [ -e "$zip_file" ] || continue
        unzip -o "$zip_file" 'Flatpaks/*' -d ./ || abortScript "Failed to unzip Flatpaks."
    done
    for zip_file in ./util/EXT*_linuxmac*.zip
    do
        [ -e "$zip_file" ] || continue
        unzip -o "$zip_file" 'dmg/*' -d ./ || abortScript "Failed to unzip dmg packages."
        if unzip -l "$zip_file" 'emulators/*/macOS/*' &>/dev/null
        then
            unzip -o "$zip_file" 'emulators/*/macOS/*' -d ./ || abortScript "Failed to unzip macOS emulators."
        fi
    done
    
    mkdir -p Update/linux_mac
    cd Update/linux_mac/
    if [ -e ver_current_linuxmac.txt ]
    then
        updateversion="$(sed -n '1p' ver_current_linuxmac.txt)" || abortScript "Missing version tracking file contents!"
        [ "$setupversion" != "$updateversion" ] && abortScript "Version mismatch for universal package update zip!"
        if [ -e update_universalpackages_linuxmac.zip ]
        then
            universal_package_sum="$(sed -n '7p' ver_current_linuxmac.txt)"
            echo "$universal_package_sum" | sha256sum --check || { rm update_universalpackages_linuxmac.zip; abortScript "Checksum for downloaded file invalid."; }
            unzip -o update_universalpackages_linuxmac.zip -d ../../../ || abortScript "Failed to unzip universal update."
        fi
        for file in ../../../Content/XO!(*zz)_linux*_Metadata.zip ../../../Content/eXo!(*zz)_linux*_Metadata.zip
        do
            [ -e "$file" ] || continue
            [ -e "${file/_linux/zz_linux}" ] && continue
            [[ "$file" =~ Content/(eXo|XO)(.*)_linux ]] && pack_id="${BASH_REMATCH[2]}" || abortScript "Failed to set pack_id."
            for _ in 1
            do
                line_match=$(grep -n "^http.*\/update_${pack_id}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset line_match
                    break
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_package_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_package_file="${custom_package_url##*/}"
                custom_package_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_package_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_package_file" ]
                then
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver
                    break
                fi
                unzip -j -o -q "$file" "eXo/Update/linux_mac/getVer_${pack_id}.sh" -d ./ 2>/dev/null
                if [ $? != 0 ]
                then
                    echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver
                    break
                fi
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_${pack_id}.sh" ] && abortScript "getVer_${pack_id}.sh missing!"
                local_version="$(head -n 1 "getVer_${pack_id}.sh" | bash)"
                if [ "$local_version" != "$custom_package_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver local_version
                    break
                fi
                echo "$custom_package_sum" | sha256sum --check || { rm "$custom_package_file"; abortScript "Checksum for $custom_package_file invalid."; }
                unzip -o "$custom_package_file" -d ../../../ || abortScript "Failed to unzip $custom_package_file"
                unset custom_package_file custom_package_url custom_package_sum custom_package_ver local_version
            done
            for mediafile in ../../../Content/${pack_id}_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpack_linux*_*.zip
            do
                [ -e "$mediafile" ] || continue
                [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
                line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset addon_type line_match
                    continue
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_addon_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_file="${custom_addon_url##*/}"
                custom_addon_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_addon_file" ]
                then
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver
                    continue
                fi
                echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
                #unlike base packs, addons store getVer files in the update files themselves
                unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
                local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
                if [ "$local_version" != "$custom_addon_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                    continue
                fi
                unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
                unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
            done
            for mediafile in ../../../Content/${pack_id}zz_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpackzz_linux*_*.zip
            do
                [ -e "$mediafile" ] || continue
                [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)zz_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
                line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset addon_type line_match
                    continue
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_addon_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_file="${custom_addon_url##*/}"
                custom_addon_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_addon_file" ]
                then
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver
                    continue
                fi
                echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
                #unlike base packs, addons store getVer files in the update files themselves
                unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
                local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
                if [ "$local_version" != "$custom_addon_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                    continue
                fi
                unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
                unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
            done
            unset pack_id
        done

        for file in ../../../Content/XO*zz_linux*_Metadata.zip ../../../Content/eXo*zz_linux*_Metadata.zip
        do
            [ -e "$file" ] || continue
            [[ "$file" =~ Content/(eXo|XO)(.*)zz_linux ]] && pack_id="${BASH_REMATCH[2]}" || abortScript "Failed to set pack_id."
            for _ in 1
            do
                line_match=$(grep -n "^http.*\/update_${pack_id}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset line_match
                    break
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_package_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_package_file="${custom_package_url##*/}"
                custom_package_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_package_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_package_file" ]
                then
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver
                    break
                fi
                unzip -j -o -q "$file" "eXo/Update/linux_mac/getVer_${pack_id}.sh" -d ./ 2>/dev/null
                if [ $? != 0 ]
                then
                    echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver
                    break
                fi
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_${pack_id}.sh" ] && abortScript "getVer_${pack_id}.sh missing!"
                local_version="$(head -n 1 "getVer_${pack_id}.sh" | bash)"
                if [ "$local_version" != "$custom_package_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset custom_package_url custom_package_file custom_package_sum custom_package_ver local_version
                    break
                fi
                echo "$custom_package_sum" | sha256sum --check || { rm "$custom_package_file"; abortScript "Checksum for $custom_package_file invalid."; }
                unzip -o "$custom_package_file" -d ../../../ || abortScript "Failed to unzip $custom_package_file"
                unset custom_package_file custom_package_url custom_package_sum custom_package_ver local_version
            done
            for mediafile in ../../../Content/${pack_id}_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpack_linux*_*.zip
            do
                [ -e "$mediafile" ] || continue
                [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
                line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset addon_type line_match
                    continue
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_addon_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_file="${custom_addon_url##*/}"
                custom_addon_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_addon_file" ]
                then
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver
                    continue
                fi
                echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
                #unlike base packs, addons store getVer files in the update files themselves
                unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
                local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
                if [ "$local_version" != "$custom_addon_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                    continue
                fi
                unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
                unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
            done
            for mediafile in ../../../Content/${pack_id}zz_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpackzz_linux*_*.zip
            do
                [ -e "$mediafile" ] || continue
                [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)zz_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
                line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" ver_current_linuxmac.txt | head -n 1)
                if [ -z "$line_match" ]
                then
                    unset addon_type line_match
                    continue
                fi
                url_line_num=$(echo "$line_match" | cut -d: -f1)
                sum_line_num=$((url_line_num + 1))
                ver_line_num=$((url_line_num - 1))
                custom_addon_url="$(sed -n "${url_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_file="${custom_addon_url##*/}"
                custom_addon_sum="$(sed -n "${sum_line_num}p" ver_current_linuxmac.txt)"
                custom_addon_ver="$(sed -n "${ver_line_num}p" ver_current_linuxmac.txt)"
                unset line_match url_line_num sum_line_num ver_line_num
                if [ ! -e "$custom_addon_file" ]
                then
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver
                    continue
                fi
                echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
                #unlike base packs, addons store getVer files in the update files themselves
                unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
                #ensure update is for the same major release as the local version
                [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
                local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
                if [ "$local_version" != "$custom_addon_ver" ]
                then
                    echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                    echo "Please download the latest torrent."
                    unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                    continue
                fi
                unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
                unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
            done
            unset pack_id
        done
    fi
    cd ../../..
}

function failedInstall
{
    printf "\n\e[1;31;47mAn error occurred while attempting to install packages.\e[0m\n\n%s\n\t%s\n\t%s\n\t%s\n\t%s\n\t%s\n\t%s\n\n" \
        "Possible causes may include:" \
        "- A lock held by automatic updates running in the background" \
        "- Insufficient sudo access or user permissions" \
        "- A problem with your package manager" \
        "- A read-only filesystem" \
        "- A zip file is corrupted" \
        "- Your computer leading a rebellion against you"
    printf "Sometimes the problem may resolve itself by rerunning this setup.\nFirst try that. If there is still a problem, consult the readme:\n%s\e[1;33;40m%s\e[0m%s\n\n" \
        "\"" "./eXo<collection> Linux ReadMe.txt" "\""
    read -s -n 1 -p "Press any key to abort."
    printf "\n\n"
    exit 1
}

# File naming convention for updates:
# Dependency installer updates: install_dependencies.bnew, install_dependencies.cnew
# Universal package updates: update_universalpackages_linuxmac.zip
# Base pack: update_${pack_id}_linux*.zip
#            Examples: update_DOS_FLP_linuxmac.zip, update_ScummVM_linuxmac.zip
# Addon pack: update_addon_${pack_id}_${addon_type}_linux*.zip
#            Examples: update_addon_DOS_Videos_linuxmac.zip, update_addon_DOS_GLP_MagazinesGLP_linuxmac.zip
# Note that Linux base packs must contain eXo/Update/linux_mac/getVer_${pack_id}.sh files for updates to work
# Note that Linux ADDON UPDATES must contain eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh to work
function getUpdate
{
    cd eXo
    if [ ! -d Update/linux_mac ]
    then
        mkdir -p Update/linux_mac || abortScript "Error creating Update directory."
    fi
    cd Update/linux_mac
    if [ -d tmp ]
    then
        rm -rf tmp || abortScript "Error removing existing tmp download directory."
    fi
    mkdir tmp || abortScript "Error creating tmp download directory."
    clear
    printf "\nChecking for updates...\n\n"
    cd tmp
    wget "https://github.com/exoscoriae/eXoDOS/raw/master/linux_mac/ver_universal_linuxmac.txt" -O ver_universal_linuxmac.txt || abortScript "Failed to retrieve update information."
    updateversion="$(sed -n '1p' ver_universal_linuxmac.txt)"
    universal_depmac_url="$(sed -n '2p' ver_universal_linuxmac.txt)"
    universal_depmac_sum="$(sed -n '3p' ver_universal_linuxmac.txt)"
    universal_deplin_url="$(sed -n '4p' ver_universal_linuxmac.txt)"
    universal_deplin_sum="$(sed -n '5p' ver_universal_linuxmac.txt)"
    universal_package_url="$(sed -n '6p' ver_universal_linuxmac.txt)"
    universal_package_sum="$(sed -n '7p' ver_universal_linuxmac.txt)"
    clear
    
    if [ -e ../ver_current_linuxmac.txt ]
    then
        if [ "$setupversion" == "$updateversion" ]
        then
            cd ..
            if [ -e install_dependencies.cnew ] || [ -e install_dependencies.bnew ]
            then
                if ! echo "$universal_depmac_sum" | sha256sum --check || ! echo "$universal_deplin_sum" | sha256sum --check
                then
                    setupversion="$setupversion (bad state)"
                fi
            fi
            cd tmp
        fi
    fi
    if [ "$setupversion" == "$updateversion" ]
    then
        printf "\nYou already have the latest version of the dependency installer.\n\n"
    else
        printf "\n%s\e[1;37;40m%s\e[0m%s\n\n%s\t\t$setupversion\n%s\t$updateversion\n\n" \
        "A dependency installer update is " "available" "." "Local version: " "Available version: "
        read -s -n 1 -p "Press any key to continue..."
        printf "\n\n"
        wget "$universal_depmac_url" -O install_dependencies.cnew || abortScript "Failed to download dependency setup."
        echo "$universal_depmac_sum" | sha256sum --check || { rm install_dependencies.cnew; abortScript "Checksum for install_dependencies.cnew invalid."; }
        mv install_dependencies.cnew ../install_dependencies.cnew || abortScript "Error replacing install_dependencies.cnew."
        wget "$universal_deplin_url" -O install_dependencies.bnew || abortScript "Failed to download dependency setup."
        echo "$universal_deplin_sum" | sha256sum --check || { rm install_dependencies.bnew; abortScript "Checksum for install_dependencies.bnew invalid."; }
        mv install_dependencies.bnew ../install_dependencies.bnew || abortScript "Error replacing install_dependencies.bnew."
        rm ver_universal_linuxmac.txt
        clear
        printf "\nDependency installer updated.\n\n%s\e[1;33;40m%s\e[0m%s\e[1;37;45m%s\e[0m%s\n\n" \
            "Run " "install_dependencies.command" " again and select [" "D" "]ownload updates."
        read -s -n 1 -p "Press any key to close..."
        printf "\n\n"
        exit 0
    fi
    
    #universal package updates
    needsDownload=yes
    [[ "$universal_package_sum" =~ ^0{64} ]] && needsDownload=no
    if [ -e ../update_universalpackages_linuxmac.zip ]
    then
        cd ..
        echo "$universal_package_sum" | sha256sum --check && needsDownload=no
        cd tmp
    fi
    if [ "$needsDownload" == "yes" ]
    then
        wget "$universal_package_url" -O update_universalpackages_linuxmac.zip || abortScript "Failed to download packages."
        echo "$universal_package_sum" | sha256sum --check || { rm update_universalpackages_linuxmac.zip; abortScript "Checksum for update_universalpackages_linuxmac.zip invalid."; }
        mv update_universalpackages_linuxmac.zip ../ || abortScript "Error moving universal packages update zip."
    fi
    unset needsDownload
    cd ..
    #unzip -o update_universalpackages_linuxmac.zip -d ../../../ || abortScript "Failed to unzip update."
    head -n 7 tmp/ver_universal_linuxmac.txt > ver_current_linuxmac.txt
    
    #Pack specific updates for collections that do not require patch to extract last (no zz) - XO*_linux*_Metadata.zip for standard, eXo*_linux*_Metadata.zip for language packs
    for file in ../../../Content/XO!(*zz)_linux*_Metadata.zip ../../../Content/eXo!(*zz)_linux*_Metadata.zip
    do
        [ -e "$file" ] || continue
        [ -e "${file/_linux/zz_linux}" ] && continue
        needsDownload=yes
        [[ "$file" =~ Content/(eXo|XO)(.*)_linux ]] && pack_id="${BASH_REMATCH[2]}" || abortScript "Failed to set pack_id."
        for _ in 1
        do
            line_match=$(grep -n "^http.*\/update_${pack_id}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset line_match
                break
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_package_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_package_file="${custom_package_url##*/}"
            custom_package_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_package_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            unzip -j -o -q "$file" "eXo/Update/linux_mac/getVer_${pack_id}.sh" -d ./ 2>/dev/null
            if [ $? != 0 ]
            then
                echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                echo "Please download the latest torrent."
                unset custom_package_url custom_package_file custom_package_sum custom_package_ver needsDownload
                break
            fi
            #ensure update is for the same major release as the local version
            local_version="$(head -n 1 "getVer_${pack_id}.sh" | bash)"
            if [ "$local_version" != "$custom_package_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                echo "Please download the latest torrent."
                unset custom_package_url custom_package_file custom_package_sum custom_package_ver local_version needsDownload
                break
            fi
            if [ -e "$custom_package_file" ]
            then
                echo "$custom_package_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_package_url" -O "$custom_package_file" || abortScript "Failed to download $custom_package_file."
                echo "$custom_package_sum" | sha256sum --check || abortScript "Checksum for $custom_package_file invalid."
                mv "$custom_package_file" ../ || abortScript "Error moving $custom_package_file."
                cd ..
            fi
            unset needsDownload
            #unzip -o "$custom_package_file" -d ../../../ || abortScript "Failed to unzip $custom_package_file."
            echo "$custom_package_ver" >> ver_current_linuxmac.txt
            echo "$custom_package_url" >> ver_current_linuxmac.txt
            echo "$custom_package_sum" >> ver_current_linuxmac.txt
            unset custom_package_file custom_package_url custom_package_sum custom_package_ver local_version needsDownload
        done
        for mediafile in ../../../Content/${pack_id}_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpack_linux*_*.zip
        do
            [ -e "$mediafile" ] || continue
            needsDownload=yes
            [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
            line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset addon_type line_match
                continue
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_addon_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_file="${custom_addon_url##*/}"
            custom_addon_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            if [ -e "$custom_addon_file" ]
            then
                echo "$custom_addon_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_addon_url" -O "$custom_addon_file" || abortScript "Failed to download $custom_addon_file."
                echo "$custom_addon_sum" | sha256sum --check || abortScript "Checksum for $custom_addon_file invalid."
                mv "$custom_addon_file" ../ || abortScript "Error moving $custom_addon_file."
                cd ..
            fi
            unset needsDownload
            echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
            #unlike base packs, addons store getVer files in the update files themselves
            unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
            #ensure update is for the same major release as the local version
            [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
            local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
            if [ "$local_version" != "$custom_addon_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                echo "Please download the latest torrent."
                unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                continue
            fi
            #unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
            echo "$custom_addon_ver" >> ver_current_linuxmac.txt
            echo "$custom_addon_url" >> ver_current_linuxmac.txt
            echo "$custom_addon_sum" >> ver_current_linuxmac.txt
            unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
        done
        for mediafile in ../../../Content/${pack_id}zz_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpackzz_linux*_*.zip
        do
            [ -e "$mediafile" ] || continue
            needsDownload=yes
            [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)zz_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
            line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset addon_type line_match
                continue
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_addon_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_file="${custom_addon_url##*/}"
            custom_addon_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            if [ -e "$custom_addon_file" ]
            then
                echo "$custom_addon_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_addon_url" -O "$custom_addon_file" || abortScript "Failed to download $custom_addon_file."
                echo "$custom_addon_sum" | sha256sum --check || abortScript "Checksum for $custom_addon_file invalid."
                mv "$custom_addon_file" ../ || abortScript "Error moving $custom_addon_file."
                cd ..
            fi
            unset needsDownload
            echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
            #unlike base packs, addons store getVer files in the update files themselves
            unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
            #ensure update is for the same major release as the local version
            [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
            local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
            if [ "$local_version" != "$custom_addon_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                echo "Please download the latest torrent."
                unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                continue
            fi
            #unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
            echo "$custom_addon_ver" >> ver_current_linuxmac.txt
            echo "$custom_addon_url" >> ver_current_linuxmac.txt
            echo "$custom_addon_sum" >> ver_current_linuxmac.txt
            unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
        done
        unset pack_id
    done

    #Pack specific updates for collections that required patch to extract last - XO*zz_linux*_Metadata.zip for standard, eXo*zz_linux*_Metadata.zip for language packs
    for file in ../../../Content/XO*zz_linux*_Metadata.zip ../../../Content/eXo*zz_linux*_Metadata.zip
    do
        [ -e "$file" ] || continue
        needsDownload=yes
        [[ "$file" =~ Content/(eXo|XO)(.*)zz_linux ]] && pack_id="${BASH_REMATCH[2]}" || abortScript "Failed to set pack_id."
        for _ in 1
        do
            line_match=$(grep -n "^http.*\/update_${pack_id}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset line_match
                break
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_package_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_package_file="${custom_package_url##*/}"
            custom_package_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_package_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            unzip -j -o -q "$file" "eXo/Update/linux_mac/getVer_${pack_id}.sh" -d ./ 2>/dev/null
            if [ $? != 0 ]
            then
                echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                echo "Please download the latest torrent."
                unset custom_package_url custom_package_file custom_package_sum custom_package_ver needsDownload
                break
            fi
            #ensure update is for the same major release as the local version
            local_version="$(head -n 1 "getVer_${pack_id}.sh" | bash)"
            if [ "$local_version" != "$custom_package_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} not compatible with your local copy."
                echo "Please download the latest torrent."
                unset custom_package_url custom_package_file custom_package_sum custom_package_ver local_version needsDownload
                break
            fi
            if [ -e "$custom_package_file" ]
            then
                echo "$custom_package_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_package_url" -O "$custom_package_file" || abortScript "Failed to download $custom_package_file."
                echo "$custom_package_sum" | sha256sum --check || abortScript "Checksum for $custom_package_file invalid."
                mv "$custom_package_file" ../ || abortScript "Error moving $custom_package_file."
                cd ..
            fi
            unset needsDownload
            #unzip -o "$custom_package_file" -d ../../../ || abortScript "Failed to unzip $custom_package_file."
            echo "$custom_package_ver" >> ver_current_linuxmac.txt
            echo "$custom_package_url" >> ver_current_linuxmac.txt
            echo "$custom_package_sum" >> ver_current_linuxmac.txt
            unset custom_package_file custom_package_url custom_package_sum custom_package_ver local_version needsDownload
        done
        for mediafile in ../../../Content/${pack_id}_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpack_linux*_*.zip
        do
            [ -e "$mediafile" ] || continue
            needsDownload=yes
            [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
            line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset addon_type line_match
                continue
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_addon_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_file="${custom_addon_url##*/}"
            custom_addon_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            if [ -e "$custom_addon_file" ]
            then
                echo "$custom_addon_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_addon_url" -O "$custom_addon_file" || abortScript "Failed to download $custom_addon_file."
                echo "$custom_addon_sum" | sha256sum --check || abortScript "Checksum for $custom_addon_file invalid."
                mv "$custom_addon_file" ../ || abortScript "Error moving $custom_addon_file."
                cd ..
            fi
            unset needsDownload
            echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
            #unlike base packs, addons store getVer files in the update files themselves
            unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
            #ensure update is for the same major release as the local version
            [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
            local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
            if [ "$local_version" != "$custom_addon_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                echo "Please download the latest torrent."
                unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                continue
            fi
            #unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
            echo "$custom_addon_ver" >> ver_current_linuxmac.txt
            echo "$custom_addon_url" >> ver_current_linuxmac.txt
            echo "$custom_addon_sum" >> ver_current_linuxmac.txt
            unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
        done
        for mediafile in ../../../Content/${pack_id}zz_linux*_*.zip ../../../Content/eXo${pack_id}_Addonpackzz_linux*_*.zip
        do
            [ -e "$mediafile" ] || continue
            needsDownload=yes
            [[ "$mediafile" =~ Content/(eXo)?"${pack_id}"(.*)zz_linux[^_]*_(.*)\.zip$ ]] && addon_type="${BASH_REMATCH[3]}" || abortScript "Failed to set media_type."
            line_match=$(grep -n "^http.*\/update_addon_${pack_id}_${addon_type}_linux.*" tmp/ver_universal_linuxmac.txt | head -n 1)
            if [ -z "$line_match" ]
            then
                unset addon_type line_match
                continue
            fi
            url_line_num=$(echo "$line_match" | cut -d: -f1)
            sum_line_num=$((url_line_num + 1))
            ver_line_num=$((url_line_num - 1))
            custom_addon_url="$(sed -n "${url_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_file="${custom_addon_url##*/}"
            custom_addon_sum="$(sed -n "${sum_line_num}p" tmp/ver_universal_linuxmac.txt)"
            custom_addon_ver="$(sed -n "${ver_line_num}p" tmp/ver_universal_linuxmac.txt)"
            unset line_match url_line_num sum_line_num ver_line_num
            if [ -e "$custom_addon_file" ]
            then
                echo "$custom_addon_sum" | sha256sum --check && needsDownload=no
            fi
            if [ "$needsDownload" == "yes" ]
            then
                cd tmp
                wget "$custom_addon_url" -O "$custom_addon_file" || abortScript "Failed to download $custom_addon_file."
                echo "$custom_addon_sum" | sha256sum --check || abortScript "Checksum for $custom_addon_file invalid."
                mv "$custom_addon_file" ../ || abortScript "Error moving $custom_addon_file."
                cd ..
            fi
            unset needsDownload
            echo "$custom_addon_sum" | sha256sum --check || { rm "$custom_addon_file"; abortScript "Checksum for $custom_addon_file invalid."; }
            #unlike base packs, addons store getVer files in the update files themselves
            unzip -j -o -q "$custom_addon_file" "eXo/Update/linux_mac/getVer_addon_${pack_id}_${addon_type}.sh" -d ./ 2>/dev/null || abortScript "Failed to extract getVer_addon_${pack_id}_${addon_type}.sh!"
            #ensure update is for the same major release as the local version
            [ ! -e "getVer_addon_${pack_id}_${addon_type}.sh" ] && abortScript "getVer_addon_${pack_id}_${addon_type}.sh missing!"
            local_version="$(head -n 1 "getVer_addon_${pack_id}_${addon_type}.sh" | bash)"
            if [ "$local_version" != "$custom_addon_ver" ]
            then
                echo "Linux/Mac update for eXo${pack_id} ${addon_type} addon not compatible with your local copy."
                echo "Please download the latest torrent."
                unset addon_type custom_addon_url custom_addon_file custom_addon_sum custom_addon_ver local_version
                continue
            fi
            #unzip -o "$custom_addon_file" -d ../../../ || abortScript "Failed to unzip $custom_addon_file"
            echo "$custom_addon_ver" >> ver_current_linuxmac.txt
            echo "$custom_addon_url" >> ver_current_linuxmac.txt
            echo "$custom_addon_sum" >> ver_current_linuxmac.txt
            unset addon_type custom_addon_file custom_addon_url custom_addon_sum custom_addon_ver local_version
        done
        unset pack_id
    done
    
    rm tmp/ver_universal_linuxmac.txt
    cd ../../..
    clear
    printf "\nUpdates downloaded successfully.\n\n"
}

function goApk
{
    command -v apk &>/dev/null || { echo "Missing apk!"; failedInstall; }
    local missing_pkgs=()
    
    { command -v fold && command -v sha256sum; } &>/dev/null || missing_pkgs+=("coreutils")
    command -v unzip &>/dev/null || missing_pkgs+=("unzip")
    command -v wget &>/dev/null || missing_pkgs+=("wget")
    if [ "$run_update" != "yes" ]
    then
        command -v tput &>/dev/null || missing_pkgs+=("ncurses")
        for check in curl ffmpeg flatpak perl python3 sed unzip wget zip
        do
            command -v "$check" &>/dev/null || missing_pkgs+=("$check")
        done
    fi
    if [ ${#missing_pkgs[@]} -gt 0 ]
    then
        printf "\nBeginning dependency installation...\n\nIf a system package is needed, you will be prompted for your password (sudo).\n\n"
        echo "Attempting to install missing packages: ${missing_pkgs[*]}"
        sudo apk update || failedInstall
        sudo apk add "${missing_pkgs[@]}" || failedInstall
    fi
    [ "$run_update" == "yes" ] && getUpdate
    extractPackages
    installFlatpaks
}

